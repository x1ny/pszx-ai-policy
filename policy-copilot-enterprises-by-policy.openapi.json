{
  "openapi": "3.0.3",
  "info": {
    "title": "政策找企业接口 OpenAPI",
    "version": "1.0.0",
    "description": "仅包含政策找企业列表接口和政策找企业统计接口。\n\n## 调用约定\n\n- 基础前缀：`/api/policy-copilot/v1`。\n- 统一响应包装：`{ code, msg, data }`。\n- `code=200` 表示业务成功；`code=500` 表示业务失败。\n- 前端浏览器调用不需要携带服务间 `X-Policy-Copilot-Service-Token`。"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:31454",
      "description": "本地联调地址"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "EnterprisesByPolicy",
      "description": "政策找企业列表与统计"
    }
  ],
  "paths": {
    "/api/policy-copilot/v1/matches/enterprises-by-policy": {
      "post": {
        "tags": ["EnterprisesByPolicy"],
        "summary": "政策找企业列表",
        "description": "读取指定政策/项目的最新预计算匹配企业，支持匹配等级、企业名称关键词和分页。分页由后端 PageHelper 处理，返回 `total/pageNum/pageSize/pages/hasNext`。",
        "operationId": "findEnterprisesByPolicy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindEnterprisesForPolicyRequest"
              },
              "examples": {
                "allLevels": {
                  "summary": "全部匹配等级",
                  "value": {
                    "policyId": 12,
                    "projectId": null,
                    "keyword": null,
                    "matchLevels": ["high", "medium", "low"],
                    "pageNum": 1,
                    "pageSize": 20
                  }
                },
                "highOnly": {
                  "summary": "高匹配、指定项目",
                  "value": {
                    "policyId": 12,
                    "projectId": 4,
                    "keyword": "测试",
                    "matchLevels": ["high"],
                    "pageNum": 1,
                    "pageSize": 20
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "匹配结果列表。`policyId` 为空时 `code=500`；空结果时 `items=[]` 且 `message` 给出空态文案。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchListResponse"
                },
                "examples": {
                  "success": {
                    "summary": "正常返回",
                    "value": {
                      "code": 200,
                      "msg": "操作成功",
                      "data": {
                        "schemaVersion": "1.0",
                        "analysisId": null,
                        "items": [
                          {
                            "matchId": "M2026071400010001",
                            "policyId": 12,
                            "projectId": 4,
                            "policyTitle": "福建省工业重点节能改造和通用设备更新提标项目",
                            "projectName": "节能改造项目",
                            "entUid": "FE8464B635C5E5464B0CAFEEEE218822",
                            "entName": "泉州市测试企业有限公司",
                            "score": 72.5,
                            "matchLevel": "medium",
                            "eligibilityStatus": "need_confirmation",
                            "confidence": 61.0,
                            "satisfiedCount": null,
                            "unsatisfiedCount": null,
                            "unknownCount": null,
                            "notApplicableCount": null,
                            "mainEvidenceSummary": []
                          }
                        ],
                        "total": 100,
                        "pageNum": 1,
                        "pageSize": 20,
                        "pages": 5,
                        "hasNext": true,
                        "message": null
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/enterprises-by-policy/summary": {
      "get": {
        "tags": ["EnterprisesByPolicy"],
        "summary": "政策找企业统计",
        "description": "统计指定政策/项目下最新预计算匹配结果的高、中、低匹配数量。该接口独立于列表分页，不接收 `pageNum/pageSize`。",
        "operationId": "summarizeEnterprisesByPolicy",
        "parameters": [
          {
            "name": "policyId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "政策 ID。",
            "example": 12
          },
          {
            "name": "projectId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "nullable": true
            },
            "description": "项目 ID；不传时统计该政策下全部项目。",
            "example": 4
          }
        ],
        "responses": {
          "200": {
            "description": "匹配企业统计。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicyEnterpriseMatchSummaryResponse"
                },
                "examples": {
                  "success": {
                    "summary": "正常返回",
                    "value": {
                      "code": 200,
                      "msg": "操作成功",
                      "data": {
                        "schemaVersion": "1.0",
                        "total": 100,
                        "highCount": 20,
                        "mediumCount": 50,
                        "lowCount": 30
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponseEnvelope": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "msg": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {
            "nullable": true
          }
        },
        "required": ["code", "msg"]
      },
      "FindEnterprisesForPolicyRequest": {
        "type": "object",
        "description": "政策找企业请求。",
        "properties": {
          "policyId": {
            "type": "integer",
            "format": "int64",
            "description": "政策 ID，必填。",
            "example": 12
          },
          "projectId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "项目 ID；切换项目时传对应值。",
            "example": 4
          },
          "keyword": {
            "type": "string",
            "nullable": true,
            "description": "企业名称关键词，服务端筛选。"
          },
          "matchLevels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["high", "medium", "low"]
            },
            "nullable": true,
            "description": "匹配等级筛选；不传时默认统计 high/medium/low。"
          },
          "pageNum": {
            "type": "integer",
            "nullable": true,
            "example": 1
          },
          "pageSize": {
            "type": "integer",
            "nullable": true,
            "example": 20
          }
        },
        "required": ["policyId"]
      },
      "MatchListResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/MatchList"
              }
            }
          }
        ]
      },
      "MatchList": {
        "type": "object",
        "description": "政策找企业分页结果。",
        "properties": {
          "schemaVersion": {
            "type": "string",
            "example": "1.0"
          },
          "analysisId": {
            "type": "string",
            "nullable": true,
            "description": "政策找企业读取预计算结果，通常为 null。"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchItem"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "总记录数。"
          },
          "pageNum": {
            "type": "integer",
            "description": "当前页码。"
          },
          "pageSize": {
            "type": "integer",
            "description": "每页大小。"
          },
          "pages": {
            "type": "integer",
            "description": "总页数。"
          },
          "hasNext": {
            "type": "boolean",
            "description": "是否还有下一页。"
          },
          "message": {
            "type": "string",
            "nullable": true,
            "description": "空态业务文案。"
          }
        },
        "required": ["schemaVersion", "items", "total", "pageNum", "pageSize", "pages", "hasNext"]
      },
      "MatchItem": {
        "type": "object",
        "description": "一条企业 + 政策 + 项目匹配结果。",
        "properties": {
          "matchId": {
            "type": "string",
            "description": "匹配结果标识。"
          },
          "policyId": {
            "type": "integer",
            "format": "int64"
          },
          "projectId": {
            "type": "integer",
            "format": "int64"
          },
          "policyTitle": {
            "type": "string"
          },
          "projectName": {
            "type": "string"
          },
          "entUid": {
            "type": "string",
            "description": "企业标识。"
          },
          "entName": {
            "type": "string",
            "nullable": true,
            "description": "企业名称。"
          },
          "score": {
            "type": "number",
            "format": "double",
            "nullable": true,
            "description": "匹配分。"
          },
          "matchLevel": {
            "type": "string",
            "nullable": true,
            "description": "匹配等级。",
            "enum": ["high", "medium", "low", "none"]
          },
          "eligibilityStatus": {
            "type": "string",
            "nullable": true,
            "description": "准入状态。",
            "enum": ["eligible", "need_confirmation", "not_eligible"]
          },
          "confidence": {
            "type": "number",
            "format": "double",
            "nullable": true,
            "description": "置信度。"
          },
          "satisfiedCount": {
            "type": "integer",
            "nullable": true,
            "description": "政策找企业接口当前为 null。"
          },
          "unsatisfiedCount": {
            "type": "integer",
            "nullable": true,
            "description": "政策找企业接口当前为 null。"
          },
          "unknownCount": {
            "type": "integer",
            "nullable": true,
            "description": "政策找企业接口当前为 null。"
          },
          "notApplicableCount": {
            "type": "integer",
            "nullable": true,
            "description": "政策找企业接口当前为 null。"
          },
          "mainEvidenceSummary": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "政策找企业接口当前为空数组。"
          }
        },
        "required": ["matchId", "policyId", "projectId", "entUid"]
      },
      "PolicyEnterpriseMatchSummaryResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ApiResponseEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/PolicyEnterpriseMatchSummary"
              }
            }
          }
        ]
      },
      "PolicyEnterpriseMatchSummary": {
        "type": "object",
        "description": "政策找企业统计，不受列表分页影响。",
        "properties": {
          "schemaVersion": {
            "type": "string",
            "example": "1.0"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "example": 100
          },
          "highCount": {
            "type": "integer",
            "format": "int64",
            "example": 20
          },
          "mediumCount": {
            "type": "integer",
            "format": "int64",
            "example": 50
          },
          "lowCount": {
            "type": "integer",
            "format": "int64",
            "example": 30
          }
        },
        "required": ["schemaVersion", "total", "highCount", "mediumCount", "lowCount"]
      }
    }
  }
}
