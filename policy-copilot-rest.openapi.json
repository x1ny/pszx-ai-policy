{
  "openapi": "3.0.3",
  "info": {
    "title": "政策匹配平台 业务 REST API",
    "version": "1.0.0",
    "description": "information-brief Java 服务对前端开放的政策匹配业务接口，对应《政策匹配平台业务前端功能对接文档》。\n\n## 调用约定\n\n- 基础前缀：`/api/policy-copilot/v1`。\n- 本期前端联调阶段免鉴权（见对接文档 §4.2）：浏览器调用不需要携带 `Authorization` 或任何服务 Token。\n- MCP server 到 Java 的服务间调用走 `X-Policy-Copilot-Service-Token` 请求头（值与 Java 侧 `policy.copilot.service-token` 一致），前端不需要携带。\n- 统一响应包装：`{ code, msg, data }`。`code=200` 表示业务成功；`code=500` 表示业务失败（HTTP 状态码仍为 200，前端必须同时检查 HTTP 状态与 `body.code`，见 §4.3）。\n\n## 日期序列化说明（重要）\n\n当前后端未配置全局 Jackson 日期格式，`java.util.Date` 字段默认序列化为 **epoch 毫秒整数**（如 `1718841600000`）。本规范中所有日期/时间字段均按 `integer(format=int64, epoch 毫秒)` 建模，以匹配真实报文。\n若希望这些字段以 ISO 字符串返回（与对接文档 TS 模型里的 `string` 一致），在 Java 侧 `application.yml` 增加：\n```yaml\nspring:\n  jackson:\n    date-format: yyyy-MM-dd HH:mm:ss\n    time-zone: GMT+8\n```\n配置变更后需同步更新本规范对应字段为 `string(format=date-time)`。\n\n## 内部标识使用规则（§4.4）\n\n`enterpriseId/entUid`、`policyId`、`projectId`、`matchId`、`indicatorId`、`fieldName` 只用作路由、查询与上下文参数，不得作为业务文案展示；页面必须展示企业名称、政策名称、项目名称和条件名称。",
    "contact": { "name": "information-brief 后端" }
  },
  "servers": [
    { "url": "http://127.0.0.1:31454", "description": "本地联调地址（对接文档 §4.1）" }
  ],
  "security": [],
  "tags": [
    { "name": "Dashboard", "description": "园区政策服务首页工作台" },
    { "name": "Search", "description": "企业/政策/项目/匹配对象搜索与解析" },
    { "name": "Context", "description": "政策与企业上下文（详情画像）" },
    { "name": "Match", "description": "企业找政策、政策找企业、匹配证据与差距" },
    { "name": "Interaction", "description": "AI 交互埋点（补充接口，对接文档未列入前端必接）" }
  ],
  "paths": {
    "/api/policy-copilot/v1/dashboard/summary": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "首页工作台概览",
        "description": "对应对接文档 §5.2。返回覆盖政策数、占位 KPI、重点政策列表等。`servedEnterpriseCount`、`matchAnalysisCount` 当前为占位值 0，前端按 `--` 或“统计建设中”展示。",
        "operationId": "getDashboardSummary",
        "responses": {
          "200": {
            "description": "概览数据。业务失败时 `code=500`、`data=null`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DashboardSummaryResponse" },
                "examples": {
                  "success": {
                    "summary": "正常返回",
                    "value": {
                      "code": 200,
                      "msg": "操作成功",
                      "data": {
                        "schemaVersion": "1.0",
                        "kpis": { "activePolicyCount": 7, "servedEnterpriseCount": 0, "matchAnalysisCount": 0 },
                        "news": [],
                        "topPolicies": [
                          { "policyId": 12, "title": "节能改造补贴", "policyAttribute": "补贴", "deadline": 1718841600000 }
                        ],
                        "topEnterprises": []
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/enterprises/search": {
      "get": {
        "tags": ["Search"],
        "summary": "搜索企业",
        "description": "对应对接文档 §10.1。按企业名称或统一社会信用代码检索，多候选时展示企业名称与信用代码让用户选择。",
        "operationId": "searchEnterprises",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "企业名称或统一社会信用代码（关键词）。",
            "example": "某科技有限公司"
          }
        ],
        "responses": {
          "200": {
            "description": "企业候选列表。`query` 为空时 `code=500`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EnterpriseSearchResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/policies/search": {
      "get": {
        "tags": ["Search"],
        "summary": "搜索政策",
        "description": "对应对接文档 §10.2。按政策名称或简称检索，支持中英文引号与常见标点差异。",
        "operationId": "searchPolicies",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "政策名称或简称。",
            "example": "节能改造"
          }
        ],
        "responses": {
          "200": {
            "description": "政策候选列表。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PolicySearchResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/projects/search": {
      "get": {
        "tags": ["Search"],
        "summary": "搜索项目",
        "description": "对应对接文档 §10.3。在指定政策范围内按项目名称检索；`policyQuery` 可选，缺省时在当前纳入匹配的全部政策内检索。",
        "operationId": "searchProjects",
        "parameters": [
          {
            "name": "policyQuery",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "限定政策名称或政策 ID。",
            "example": "节能改造补贴"
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "项目名称或项目 ID。",
            "example": "节能改造项目"
          }
        ],
        "responses": {
          "200": {
            "description": "项目候选列表。`query` 为空时 `code=500`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectSearchResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/resolve": {
      "get": {
        "tags": ["Search"],
        "summary": "解析匹配对象",
        "description": "对应对接文档 §10.4。可传 `query/enterpriseQuery/policyQuery/projectQuery`。多条结果时按企业、政策和项目名称让用户选择，不要求用户输入内部标识。",
        "operationId": "resolveMatches",
        "parameters": [
          { "name": "query", "in": "query", "required": false, "schema": { "type": "string" }, "description": "matchId 或综合关键词。" },
          { "name": "enterpriseQuery", "in": "query", "required": false, "schema": { "type": "string" }, "description": "企业名称或统一社会信用代码。" },
          { "name": "policyQuery", "in": "query", "required": false, "schema": { "type": "string" }, "description": "政策名称或政策 ID。" },
          { "name": "projectQuery", "in": "query", "required": false, "schema": { "type": "string" }, "description": "项目名称或项目 ID。" }
        ],
        "responses": {
          "200": {
            "description": "匹配对象候选列表。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MatchResolveResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/enterprises/{entUid}/context": {
      "get": {
        "tags": ["Context"],
        "summary": "企业政策画像",
        "description": "对应对接文档 §7.3。路径变量为 `entUid`（对接文档称 `enterpriseId`）。前端优先使用 `entName/creditCode/province/city/industryCategory/profileItems/missingDataItems/abnormalFields`；`serviceProfile/indicators/missingFields` 为内部字段，前端不直接渲染。",
        "operationId": "getEnterpriseContext",
        "parameters": [
          {
            "name": "entUid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "企业标识（`entUid`，对接文档中称 `enterpriseId`）。",
            "example": "10583BAEC594416585810EE1BF62514A"
          }
        ],
        "responses": {
          "200": {
            "description": "企业政策画像。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EnterprisePolicyContextResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/policies/{policyId}/context": {
      "get": {
        "tags": ["Context"],
        "summary": "政策详情与项目条件",
        "description": "对应对接文档 §6.3。返回政策基础信息与 `projects[].conditions[]`。条件字段映射见 §6.3：`indicator` 为指标名称、`compare+fieldVal` 为条件内容、`conditionRole==='must'` 为必要、`sourceClause` 为原文依据。`fieldName/indicatorId/indicatorScore` 为内部字段，前端不展示。",
        "operationId": "getPolicyContext",
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "description": "政策 ID。",
            "example": 12
          }
        ],
        "responses": {
          "200": {
            "description": "政策上下文。政策不存在时 `code=500`、`msg=\"政策不存在\"`、`data=null`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PolicyMatchContextResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/policies-by-enterprise": {
      "post": {
        "tags": ["Match"],
        "summary": "企业找政策（实时匹配）",
        "description": "对应对接文档 §7.4。以 `entUid` 或 `enterpriseId` 为企业键实时计算并写入匹配结果。每条结果为“企业 + 政策 + 项目”，政策相同但项目不同必须保留为不同行。注意：DTO 中的 `matchLevels/policyAttribute/sort/pageNum/pageSize` 当前实时流程尚未实际应用，前端不得依赖其做服务端筛选与分页；前端按返回 `items[]` 自行聚合高中低数量。",
        "operationId": "findPoliciesByEnterprise",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FindPoliciesForEnterpriseRequest" },
              "examples": {
                "byEnterpriseId": {
                  "summary": "按企业标识查询",
                  "value": { "enterpriseId": "10583BAEC594416585810EE1BF62514A" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "匹配结果列表。空结果时 `items=[]` 且 `message=\"暂无匹配结果，请确认企业画像数据是否存在\"`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MatchListResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/enterprises-by-policy": {
      "post": {
        "tags": ["EnterprisesByPolicy"],
        "summary": "政策找企业列表",
        "description": "读取指定政策/项目的最新预计算匹配企业，支持匹配等级、企业名称关键词和分页。分页由后端 PageHelper 处理，返回 `total/pageNum/pageSize/pages/hasNext`。",
        "operationId": "findEnterprisesByPolicy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindEnterprisesForPolicyRequest"
              },
              "examples": {
                "allLevels": {
                  "summary": "全部匹配等级",
                  "value": {
                    "policyId": 12,
                    "projectId": null,
                    "keyword": null,
                    "matchLevels": ["high", "medium", "low"],
                    "pageNum": 1,
                    "pageSize": 20
                  }
                },
                "highOnly": {
                  "summary": "高匹配、指定项目",
                  "value": {
                    "policyId": 12,
                    "projectId": 4,
                    "keyword": "测试",
                    "matchLevels": ["high"],
                    "pageNum": 1,
                    "pageSize": 20
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "匹配结果列表。`policyId` 为空时 `code=500`；空结果时 `items=[]` 且 `message` 给出空态文案。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchListResponse"
                },
                "examples": {
                  "success": {
                    "summary": "正常返回",
                    "value": {
                      "code": 200,
                      "msg": "操作成功",
                      "data": {
                        "schemaVersion": "1.0",
                        "analysisId": null,
                        "items": [
                          {
                            "matchId": "M2026071400010001",
                            "policyId": 12,
                            "projectId": 4,
                            "policyTitle": "福建省工业重点节能改造和通用设备更新提标项目",
                            "projectName": "节能改造项目",
                            "entUid": "FE8464B635C5E5464B0CAFEEEE218822",
                            "entName": "泉州市测试企业有限公司",
                            "score": 72.5,
                            "matchLevel": "medium",
                            "eligibilityStatus": "need_confirmation",
                            "confidence": 61.0,
                            "satisfiedCount": null,
                            "unsatisfiedCount": null,
                            "unknownCount": null,
                            "notApplicableCount": null,
                            "mainEvidenceSummary": []
                          }
                        ],
                        "total": 100,
                        "pageNum": 1,
                        "pageSize": 20,
                        "pages": 5,
                        "hasNext": true,
                        "message": null
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/enterprises-by-policy/summary": {
      "get": {
        "tags": ["EnterprisesByPolicy"],
        "summary": "政策找企业统计",
        "description": "统计指定政策/项目下最新预计算匹配结果的高、中、低匹配数量。该接口独立于列表分页，不接收 `pageNum/pageSize`。",
        "operationId": "summarizeEnterprisesByPolicy",
        "parameters": [
          {
            "name": "policyId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "政策 ID。",
            "example": 12
          },
          {
            "name": "projectId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "nullable": true
            },
            "description": "项目 ID；不传时统计该政策下全部项目。",
            "example": 4
          }
        ],
        "responses": {
          "200": {
            "description": "匹配企业统计。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicyEnterpriseMatchSummaryResponse"
                },
                "examples": {
                  "success": {
                    "summary": "正常返回",
                    "value": {
                      "code": 200,
                      "msg": "操作成功",
                      "data": {
                        "schemaVersion": "1.0",
                        "total": 100,
                        "highCount": 20,
                        "mediumCount": 50,
                        "lowCount": 30
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/{matchId}/evidence": {
      "get": {
        "tags": ["Match"],
        "summary": "匹配条件证据",
        "description": "对应对接文档 §6.5。按四态分组展示：`satisfied` 已满足、`unsatisfied` 明确不满足、`unknown` 待补充或待确认、`not_applicable` 不适用。禁止把 `unknown` 归入“不满足”。",
        "operationId": "getMatchEvidence",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "匹配结果标识。",
            "example": "match_xxx"
          }
        ],
        "responses": {
          "200": {
            "description": "条件证据列表。`matchId` 不存在时 `code=500`、`msg=\"MATCH_NOT_FOUND\"`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MatchEvidenceResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/{matchId}/gaps": {
      "get": {
        "tags": ["Match"],
        "summary": "匹配差距与材料提示",
        "description": "对应对接文档 §6.5。`missingData` 为 `evidenceStatus=unknown` 的证据，`unsatisfied` 为 `unsatisfied` 的证据。`materials[]` 当前为通用提示，不是正式材料清单，页面标题应使用“材料准备提示”，不能标成“缺失材料明细”。",
        "operationId": "getMatchGaps",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "匹配结果标识。",
            "example": "match_xxx"
          }
        ],
        "responses": {
          "200": {
            "description": "差距与材料提示。`matchId` 不存在时 `code=500`、`msg=\"MATCH_NOT_FOUND\"`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MatchGapsResponse" }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/ai-interactions": {
      "post": {
        "tags": ["Interaction"],
        "summary": "记录 AI 交互日志（补充接口）",
        "description": "对接文档未将此接口列入前端必接范围，仅作为 AI 交互埋点补充。返回 `data` 为是否写入成功（布尔）。",
        "operationId": "logAiInteraction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AiInteractionLogRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "是否写入成功。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BooleanResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponseEnvelope": {
        "type": "object",
        "description": "统一响应包装。`code=200` 业务成功；`code=500` 业务失败（HTTP 仍为 200）。前端必须同时检查 HTTP 状态与 `body.code`。",
        "properties": {
          "code": { "type": "integer", "description": "200=成功，500=失败。", "example": 200 },
          "msg": { "type": "string", "description": "提示信息；失败时为业务错误说明或错误码（如 `MATCH_NOT_FOUND`）。", "example": "操作成功" },
          "data": { "nullable": true, "description": "业务数据，失败时为 null。" }
        },
        "required": ["code", "msg"]
      },
      "DashboardSummaryResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          {
            "type": "object",
            "properties": { "data": { "$ref": "#/components/schemas/DashboardSummary" } }
          }
        ]
      },
      "DashboardSummary": {
        "type": "object",
        "description": "首页概览。",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "kpis": { "$ref": "#/components/schemas/DashboardKpis" },
          "news": { "type": "array", "items": { "type": "object", "additionalProperties": true }, "description": "今日快讯，当前为空数组；空时显示“暂无快讯”。" },
          "topPolicies": { "type": "array", "items": { "$ref": "#/components/schemas/TopPolicy" }, "description": "重点政策列表。" },
          "topEnterprises": { "type": "array", "items": { "type": "object", "additionalProperties": true }, "description": "重点企业列表，本期无数据，前端隐藏。" }
        },
        "required": ["schemaVersion", "kpis", "news", "topPolicies", "topEnterprises"]
      },
      "DashboardKpis": {
        "type": "object",
        "properties": {
          "activePolicyCount": { "type": "integer", "description": "覆盖政策数（已完成）。", "example": 7 },
          "servedEnterpriseCount": { "type": "integer", "description": "已服务企业数，当前占位 0，前端显示 `--`。", "example": 0 },
          "matchAnalysisCount": { "type": "integer", "description": "累计匹配分析，当前占位 0，前端显示 `--`。", "example": 0 }
        },
        "required": ["activePolicyCount", "servedEnterpriseCount", "matchAnalysisCount"]
      },
      "TopPolicy": {
        "type": "object",
        "properties": {
          "policyId": { "type": "integer", "format": "int64", "example": 12 },
          "title": { "type": "string", "example": "节能改造补贴" },
