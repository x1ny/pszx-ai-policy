{
  "openapi": "3.0.3",
  "info": {
    "title": "Policy Copilot API",
    "version": "2026-07-22",
    "description": "政策 Copilot 前端接入 REST API。所有接口基础路径为 /api/policy-copilot/v1，响应统一为 { code, msg, data }。"
  },
  "tags": [
    {
      "name": "Dashboard",
      "description": "服务工作台看板"
    },
    {
      "name": "Search",
      "description": "企业、政策、项目和匹配结果搜索解析"
    },
    {
      "name": "Context",
      "description": "企业画像和政策条件上下文"
    },
    {
      "name": "Match",
      "description": "企业找政策、政策找企业、匹配证据和缺口"
    },
    {
      "name": "Interaction",
      "description": "AI 交互日志"
    }
  ],
  "paths": {
    "/api/policy-copilot/v1/dashboard/summary": {
      "get": {
        "tags": [
          "Dashboard"
        ],
        "summary": "服务工作台总览",
        "description": "返回 KPI、热门政策和企业找政策看板列表。topEnterprises 包含企业名称、所属节点和高匹配政策数。",
        "operationId": "getDashboardSummary",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/analysis/park-policy-match-rate": {
      "get": {
        "tags": [
          "Dashboard"
        ],
        "summary": "园区政策覆盖度",
        "description": "返回全园区和上游/中游/下游政策覆盖度。matchRate 为 0~1 小数，前端乘 100 展示百分比。",
        "operationId": "getParkPolicyMatchRate",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParkPolicyMatchRateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/enterprises/search": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "搜索企业",
        "operationId": "searchEnterprises",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "企业名称或统一社会信用代码"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnterpriseSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/policies/search": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "搜索政策",
        "operationId": "searchPolicies",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "政策名称或政策 ID"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicySearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/projects/search": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "搜索政策项目",
        "operationId": "searchProjects",
        "parameters": [
          {
            "name": "policyQuery",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "政策名称或政策 ID，可选"
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "项目名称或项目 ID"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/resolve": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "解析匹配结果",
        "description": "可通过 matchId、政策关键词、企业关键词和项目关键词定位匹配结果。",
        "operationId": "resolveMatches",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "enterpriseQuery",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "policyQuery",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectQuery",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResolveResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/enterprises/{entUid}/context": {
      "get": {
        "tags": [
          "Context"
        ],
        "summary": "企业画像上下文",
        "description": "返回企业基础信息、指标画像、可展示画像项和缺失项。ent_reg_status 按 financial_ent_basic_indicator 取值。",
        "operationId": "getEnterpriseContext",
        "parameters": [
          {
            "name": "entUid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "企业唯一标识"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnterpriseContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/policies/{policyId}/context": {
      "get": {
        "tags": [
          "Context"
        ],
        "summary": "政策匹配上下文",
        "description": "返回政策基础信息、项目和项目下条件。条件按 project_id + policy_id 交集取得。",
        "operationId": "getPolicyContext",
        "parameters": [
          {
            "name": "policyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "政策 ID"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicyContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/policies-by-enterprise": {
      "post": {
        "tags": [
          "Match"
        ],
        "summary": "企业找政策",
        "description": "按企业实时执行当前政策范围内的匹配，并返回政策-项目匹配结果。",
        "operationId": "matchPoliciesByEnterprise",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindPoliciesForEnterpriseReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/enterprises-by-policy": {
      "post": {
        "tags": [
          "Match"
        ],
        "summary": "政策找企业列表",
        "description": "分页查询某政策或政策项目下最新匹配企业结果。",
        "operationId": "findEnterprisesByPolicy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindEnterprisesForPolicyReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/enterprises-by-policy/summary": {
      "get": {
        "tags": [
          "Match"
        ],
        "summary": "政策找企业统计",
        "description": "返回高/中/低匹配企业数，企业数按 ent_uid 去重。",
        "operationId": "getEnterprisesByPolicySummary",
        "parameters": [
          {
            "name": "policyId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "projectId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PolicyEnterpriseMatchSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/{matchId}/evidence": {
      "get": {
        "tags": [
          "Match"
        ],
        "summary": "匹配证据明细",
        "operationId": "getMatchEvidence",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchEvidenceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/matches/{matchId}/gaps": {
      "get": {
        "tags": [
          "Match"
        ],
        "summary": "匹配缺口诊断",
        "operationId": "getMatchGaps",
        "parameters": [
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchGapsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/policy-copilot/v1/ai-interactions": {
      "post": {
        "tags": [
          "Interaction"
        ],
        "summary": "保存 AI 交互日志",
        "operationId": "saveAiInteraction",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiInteractionLogReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BooleanResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "msg": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {}
        },
        "required": [
          "code",
          "msg"
        ]
      },
      "DashboardSummaryResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/DashboardSummary"
              }
            }
          }
        ]
      },
      "DashboardSummary": {
        "type": "object",
        "properties": {
          "schemaVersion": {
            "type": "string",
            "example": "1.0"
          },
          "kpis": {
            "$ref": "#/components/schemas/DashboardKpis"
          },
          "news": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "topPolicies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TopPolicy"
            }
          },
          "topEnterprises": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TopEnterprise"
            }
          }
        }
      },
      "DashboardKpis": {
        "type": "object",
        "properties": {
          "activePolicyCount": {
            "type": "integer"
          },
          "servedEnterpriseCount": {
            "type": "integer"
          },
          "matchAnalysisCount": {
            "type": "integer"
          }
        }
      },
      "TopPolicy": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "integer",
            "format": "int64"
          },
          "title": {
            "type": "string"
          },
          "policyAttribute": {
            "type": "string"
          },
          "deadline": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "matchedEnterpriseCount": {
            "type": "integer",
            "format": "int64",
            "description": "最新匹配结果下去重企业数"
          }
        }
      },
      "TopEnterprise": {
        "type": "object",
        "properties": {
          "entUid": {
            "type": "string"
          },
          "entName": {
            "type": "string"
          },
          "nodeName": {
            "type": "string",
            "nullable": true,
            "description": "所属产业链节点，多个节点用顿号分隔"
          },
          "matchedPolicyCount": {
            "type": "integer",
            "format": "int64",
            "description": "高匹配政策数，is_latest=1 且 match_level=high 的去重政策数"
          },
          "maxScore": {
            "type": "number"
          }
        }
      },
      "ParkPolicyMatchRateResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/ParkPolicyMatchRate"
              }
            }
          }
        ]
      },
      "ParkPolicyMatchRate": {
        "type": "object",
        "properties": {
          "schemaVersion": {
            "type": "string",
            "example": "1.0"
          },
          "overall": {
            "$ref": "#/components/schemas/MatchRateStat"
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchRateStat"
            }
          }
        }
      },
      "MatchRateStat": {
        "type": "object",
        "properties": {
          "chainPosition": {
            "type": "string",
            "nullable": true,
            "enum": [
              "上游",
              "中游",
              "下游",
              null
            ]
          },
          "totalCount": {
            "type": "integer",
            "format": "int64"
          },
          "matchedCount": {
            "type": "integer",
            "format": "int64"
          },
          "matchRate": {
            "type": "number",
            "format": "double",
            "description": "0~1 小数"
          }
        }
      },
      "EnterpriseSearchResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EnterpriseSearchItem"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "EnterpriseSearchItem": {
        "type": "object",
        "properties": {
          "enterpriseId": {
            "type": "string"
          },
          "enterpriseName": {
            "type": "string"
          },
          "creditCode": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PolicySearchResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/PolicySearchItem"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "PolicySearchItem": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "integer",
            "format": "int64"
          },
          "policyName": {
            "type": "string"
          },
          "policyFullName": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ProjectSearchResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/ProjectSearchItem"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "ProjectSearchItem": {
        "type": "object",
        "properties": {
          "policyId": {
            "type": "integer",
            "format": "int64"
          },
          "policyName": {
            "type": "string"
          },
          "projectId": {
            "type": "integer",
            "format": "int64"
          },
          "projectName": {
            "type": "string"
          }
        }
      },
      "MatchResolveResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/MatchResolveItem"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "MatchResolveItem": {
        "type": "object",
        "properties": {
          "matchId": {
            "type": "string"
          },
          "policyId": {
            "type": "integer",
            "format": "int64"
          },
          "policyName": {
            "type": "string"
          },
          "projectId": {
            "type": "integer",
            "format": "int64"
          },
          "projectName": {
            "type": "string"
          },
          "enterpriseId": {
            "type": "string"
          },
          "enterpriseName": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "matchLevel": {
            "$ref": "#/components/schemas/MatchLevel"
          }
        }
      },
      "EnterpriseContextResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/EnterpriseContext"
              }
            }
          }
        ]
      },
      "EnterpriseContext": {
        "type": "object",
        "properties": {
          "schemaVersion": {
            "type": "string"
          },
          "entUid": {
            "type": "string"
          },
          "entName": {
            "type": "string"
          },
          "creditCode": {
            "type": "string",
            "nullable": true
          },
          "province": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "industryCategory": {
            "type": "string",
            "nullable": true
          },
          "registeredCapital": {
            "type": "string",
            "nullable": true
          },
          "enterpriseScale": {
            "type": "string",
            "nullable": true
          },
          "serviceProfile": {
            "type": "object",
            "nullable": true
          },
          "indicators": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EnterpriseIndicatorValue"
            }
          },
          "profileItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProfileItem"
            }
          },
          "missingFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingDataItems": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "abnormalFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "EnterpriseIndicatorValue": {
        "type": "object",
        "properties": {
          "fieldName": {
            "type": "string"
          },
          "fieldValue": {
            "type": "string",
            "nullable": true
          },
          "valueType": {
            "type": "string",
            "nullable": true
          },
          "unit": {
            "type": "string",
            "nullable": true
          },
          "sourceType": {
            "type": "string",
            "nullable": true
          },
          "sourceRef": {
            "type": "string",
            "nullable": true
          },
          "verifiedStatus": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "ProfileItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "nullable": true
          },
          "unit": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
