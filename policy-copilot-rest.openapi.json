          { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/EnterprisePolicyContext" } } }
        ]
      },
      "EnterprisePolicyContext": {
        "type": "object",
        "description": "企业政策画像。",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "entUid": { "type": "string", "description": "企业标识。" },
          "entName": { "type": "string", "description": "企业名称。" },
          "creditCode": { "type": "string", "nullable": true, "description": "统一社会信用代码。" },
          "province": { "type": "string", "nullable": true },
          "city": { "type": "string", "nullable": true },
          "industryCategory": { "type": "string", "nullable": true, "description": "行业。" },
          "serviceProfile": { "type": "object", "additionalProperties": true, "nullable": true, "description": "业务服务画像，内部字段，不是稳定前端契约，前端不直接渲染。" },
          "indicators": { "type": "array", "items": { "$ref": "#/components/schemas/EnterpriseIndicatorValue" }, "description": "内部指标值，前端不直接渲染。" },
          "profileItems": { "type": "array", "items": { "$ref": "#/components/schemas/ProfileItem" }, "description": "业务化画像项，前端展示业务名称、值、来源、更新时间。" },
          "missingFields": { "type": "array", "items": { "type": "string" }, "description": "内部缺失字段名列表，前端不直接渲染。" },
          "missingDataItems": { "type": "array", "items": { "type": "string" }, "description": "业务化缺失数据项，前端可展示。" },
          "abnormalFields": { "type": "array", "items": { "type": "string" }, "description": "异常字段。" }
        },
        "required": ["schemaVersion", "entUid", "entName", "profileItems", "missingFields", "missingDataItems", "abnormalFields"]
      },
      "ProfileItem": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "业务名称。" },
          "value": { "type": "string", "nullable": true, "description": "值。" },
          "unit": { "type": "string", "nullable": true, "description": "单位。" },
          "status": { "type": "string", "description": "业务数据状态，如 已核验/已获取/待补充。" },
          "source": { "type": "string", "description": "业务数据来源，如 工商登记信息/企业补充信息/待补充。" },
          "updatedAt": { "type": "integer", "format": "int64", "nullable": true, "description": "更新时间，epoch 毫秒。" }
        },
        "required": ["name", "status", "source"]
      },
      "EnterpriseIndicatorValue": {
        "type": "object",
        "description": "企业指标值（内部字段，前端不直接渲染）。",
        "properties": {
          "fieldName": { "type": "string", "description": "内部字段名。" },
          "fieldValue": { "type": "string", "nullable": true },
          "valueType": { "type": "string", "nullable": true, "description": "缺失时为 `unknown`。" },
          "unit": { "type": "string", "nullable": true },
          "sourceType": { "type": "string", "nullable": true, "description": "如 financial_ent_basic/policy_enterprise_indicator/missing/derived。" },
          "sourceRef": { "type": "string", "nullable": true },
          "verifiedStatus": { "type": "string", "nullable": true },
          "updatedAt": { "type": "integer", "format": "int64", "nullable": true, "description": "更新时间，epoch 毫秒。" }
        }
      },
      "PolicyMatchContextResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/PolicyMatchContext" } } }
        ]
      },
      "PolicyMatchContext": {
        "type": "object",
        "description": "政策详情与项目条件。",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "policyId": { "type": "integer", "format": "int64", "example": 12 },
          "title": { "type": "string", "example": "节能改造补贴" },
          "titleFull": { "type": "string", "nullable": true, "description": "政策全称。" },
          "documentNo": { "type": "string", "nullable": true, "description": "发文文号。" },
          "issuingOrg": { "type": "string", "nullable": true, "description": "发布单位。" },
          "region": { "type": "string", "nullable": true, "description": "地区。" },
          "level": { "type": "string", "nullable": true, "description": "政策级别。" },
          "policyAttribute": { "type": "string", "nullable": true, "description": "政策属性/支持方式。" },
          "deadline": { "type": "integer", "format": "int64", "nullable": true, "description": "申报截止时间，epoch 毫秒；前端可计算剩余天数。" },
          "materials": { "type": "string", "nullable": true, "description": "申报材料（文本）。" },
          "process": { "type": "string", "nullable": true, "description": "办理流程（文本）。" },
          "projects": { "type": "array", "items": { "$ref": "#/components/schemas/PolicyProjectItem" } }
        },
        "required": ["schemaVersion", "policyId", "title", "projects"]
      },
      "PolicyProjectItem": {
        "type": "object",
        "properties": {
          "projectId": { "type": "integer", "format": "int64", "example": 4 },
          "projectName": { "type": "string", "example": "节能改造项目" },
          "subjectType": { "type": "string", "nullable": true, "description": "主体类型，如 enterprise。" },
          "groupsRelation": { "type": "string", "nullable": true, "description": "条件分组关系，如 OR。" },
          "conditions": { "type": "array", "items": { "$ref": "#/components/schemas/PolicyConditionItem" } }
        },
        "required": ["projectId", "projectName", "conditions"]
      },
      "PolicyConditionItem": {
        "type": "object",
        "description": "申报条件。前端展示 `indicator`、`compare+fieldVal`、`conditionRole`、`sourceClause`；不展示 `fieldName/indicatorId/indicatorScore`。",
        "properties": {
          "indicatorId": { "type": "integer", "format": "int64", "nullable": true, "description": "内部标识，不展示。" },
          "indicator": { "type": "string", "description": "指标名称（业务文案）。" },
          "fieldName": { "type": "string", "nullable": true, "description": "内部字段名，不展示。" },
          "compare": { "type": "string", "nullable": true, "description": "比较运算符，如 EQ/GTE 等。" },
          "fieldVal": { "type": "string", "nullable": true, "description": "条件值/阈值。" },
          "conditionRole": { "type": "string", "nullable": true, "description": "条件角色。", "enum": ["must", "optional"] },
          "indicatorScore": { "type": "integer", "nullable": true, "description": "内部评分权重，不展示。" },
          "sourceClause": { "type": "string", "nullable": true, "description": "政策原文依据。" },
          "matchStatus": { "type": "string", "nullable": true, "description": "条件状态。", "enum": ["enabled", "manual_confirm", "disabled"] }
        },
        "required": ["indicator"]
      },
      "FindPoliciesForEnterpriseRequest": {
        "type": "object",
        "description": "企业找政策请求。仅 `entUid` 或 `enterpriseId` 为必填企业键；其余字段当前实时流程未实际应用。",
        "properties": {
          "entUid": { "type": "string", "nullable": true, "description": "企业标识（与 `enterpriseId` 二选一）。" },
          "enterpriseId": { "type": "string", "nullable": true, "description": "企业标识（与 `entUid` 二选一）。" },
          "entName": { "type": "string", "nullable": true },
          "creditCode": { "type": "string", "nullable": true },
          "policyAttribute": { "type": "string", "nullable": true, "description": "当前未应用。" },
          "matchLevels": { "type": "array", "items": { "type": "string", "enum": ["high", "medium", "low", "none"] }, "nullable": true, "description": "当前未应用，前端按返回结果自行聚合。" },
          "sort": { "type": "string", "nullable": true, "description": "当前未应用。" },
          "pageNum": { "type": "integer", "nullable": true, "description": "当前未应用。" },
          "pageSize": { "type": "integer", "nullable": true, "description": "当前未应用。" }
        }
      },
      "FindEnterprisesForPolicyRequest": {
        "type": "object",
        "description": "政策找企业请求。",
        "properties": {
          "policyId": { "type": "integer", "format": "int64", "description": "政策 ID（必填）。", "example": 12 },
          "projectId": { "type": "integer", "format": "int64", "nullable": true, "description": "项目 ID；切换项目时传对应值，不限定传 null。", "example": 4 },
          "keyword": { "type": "string", "nullable": true, "description": "企业名称关键词，服务端筛选。" },
          "matchLevels": { "type": "array", "items": { "type": "string", "enum": ["high", "medium", "low", "none"] }, "nullable": true, "description": "匹配等级筛选：high/medium/low，全部传三者。" },
          "pageNum": { "type": "integer", "nullable": true, "example": 1 },
          "pageSize": { "type": "integer", "nullable": true, "example": 20 }
        },
        "required": ["policyId"]
      },
      "MatchListResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/MatchList" } } }
        ]
      },
      "MatchList": {
        "type": "object",
        "description": "匹配结果列表。空结果时 `items=[]` 且 `message` 给出业务化空态文案。",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "analysisId": { "type": "string", "nullable": true, "description": "分析批次 ID（企业找政策返回）。" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/MatchItem" } },
          "total": { "type": "integer", "format": "int64", "description": "政策找企业列表总记录数。" },
          "pageNum": { "type": "integer", "description": "当前页码。" },
          "pageSize": { "type": "integer", "description": "每页大小。" },
          "pages": { "type": "integer", "description": "总页数。" },
          "hasNext": { "type": "boolean", "description": "是否还有下一页。" },
          "message": { "type": "string", "nullable": true, "description": "空态业务文案。" }
        },
        "required": ["schemaVersion", "items", "total", "pageNum", "pageSize", "pages", "hasNext"]
      },
      "MatchItem": {
        "type": "object",
        "description": "一条“企业 + 政策 + 项目”匹配结果。注意：政策找企业接口返回时四态计数为 null、`mainEvidenceSummary` 为空数组；企业找政策接口返回时四态计数与主证据摘要有值。",
        "properties": {
          "matchId": { "type": "string", "description": "匹配结果标识。" },
          "policyId": { "type": "integer", "format": "int64" },
          "projectId": { "type": "integer", "format": "int64" },
          "policyTitle": { "type": "string" },
          "projectName": { "type": "string" },
          "entUid": { "type": "string", "description": "企业标识。" },
          "entName": { "type": "string", "nullable": true, "description": "企业名称（政策找企业返回，企业找政策可能为 null）。" },
          "score": { "type": "number", "format": "double", "nullable": true, "description": "匹配分。" },
          "matchLevel": { "type": "string", "nullable": true, "description": "匹配等级。", "enum": ["high", "medium", "low", "none"] },
          "eligibilityStatus": { "type": "string", "nullable": true, "description": "准入状态。", "enum": ["eligible", "need_confirmation", "not_eligible"] },
          "confidence": { "type": "number", "format": "double", "nullable": true, "description": "置信度。" },
          "satisfiedCount": { "type": "integer", "nullable": true, "description": "已满足条件数。" },
          "unsatisfiedCount": { "type": "integer", "nullable": true, "description": "明确不满足条件数。" },
          "unknownCount": { "type": "integer", "nullable": true, "description": "待补充或待确认条件数。" },
          "notApplicableCount": { "type": "integer", "nullable": true, "description": "不适用条件数。" },
          "mainEvidenceSummary": { "type": "array", "items": { "type": "string" }, "description": "主证据摘要（前 5 条）。" }
        },
        "required": ["matchId", "policyId", "projectId", "policyTitle", "projectName", "entUid"]
      },
      "PolicyEnterpriseMatchSummaryResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/PolicyEnterpriseMatchSummary" } } }
        ]
      },
      "PolicyEnterpriseMatchSummary": {
        "type": "object",
        "description": "政策找企业统计，不受列表分页影响。",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "total": { "type": "integer", "format": "int64", "example": 100 },
          "highCount": { "type": "integer", "format": "int64", "example": 20 },
          "mediumCount": { "type": "integer", "format": "int64", "example": 50 },
          "lowCount": { "type": "integer", "format": "int64", "example": 30 }
        },
        "required": ["schemaVersion", "total", "highCount", "mediumCount", "lowCount"]
      },
      "MatchEvidenceResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/MatchEvidence" } } }
        ]
      },
      "MatchEvidence": {
        "type": "object",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "matchId": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/PolicyMatchEvidence" } }
        },
        "required": ["schemaVersion", "matchId", "items"]
      },
      "MatchGapsResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/MatchGaps" } } }
        ]
      },
      "MatchGaps": {
        "type": "object",
        "properties": {
          "schemaVersion": { "type": "string", "example": "1.0" },
          "matchId": { "type": "string" },
          "missingData": { "type": "array", "items": { "$ref": "#/components/schemas/PolicyMatchEvidence" }, "description": "`evidenceStatus=unknown` 的证据。" },
          "unsatisfied": { "type": "array", "items": { "$ref": "#/components/schemas/PolicyMatchEvidence" }, "description": "`evidenceStatus=unsatisfied` 的证据。" },
          "materials": { "type": "array", "items": { "type": "string" }, "description": "材料准备提示（通用，非正式材料清单）。" }
        },
        "required": ["schemaVersion", "matchId", "missingData", "unsatisfied", "materials"]
      },
      "PolicyMatchEvidence": {
        "type": "object",
        "description": "单条条件证据。前端按 `evidenceStatus` 分组；`fieldName/indicatorId` 为内部字段不展示。",
        "properties": {
          "id": { "type": "integer", "format": "int64", "nullable": true, "description": "内部主键。" },
          "matchId": { "type": "string", "nullable": true },
          "indicatorId": { "type": "integer", "format": "int64", "nullable": true, "description": "内部标识，不展示。" },
          "evidenceStatus": { "type": "string", "description": "四态证据状态。", "enum": ["satisfied", "unsatisfied", "unknown", "not_applicable"] },
          "enterpriseValue": { "type": "string", "nullable": true, "description": "企业实际值。" },
          "policyValue": { "type": "string", "nullable": true, "description": "政策要求值。" },
          "scoreWeight": { "type": "number", "format": "double", "nullable": true, "description": "权重。" },
          "scoreObtained": { "type": "number", "format": "double", "nullable": true, "description": "得分。" },
          "dataSource": { "type": "string", "nullable": true, "description": "数据来源。" },
          "dataTime": { "type": "integer", "format": "int64", "nullable": true, "description": "数据时间，epoch 毫秒。" },
          "reason": { "type": "string", "nullable": true, "description": "判定原因。" },
          "createdAt": { "type": "integer", "format": "int64", "nullable": true, "description": "创建时间，epoch 毫秒。" },
          "fieldName": { "type": "string", "nullable": true, "description": "内部字段名，不展示。" },
          "compare": { "type": "string", "nullable": true, "description": "比较运算符。" },
          "indicator": { "type": "string", "nullable": true, "description": "指标名称（业务文案）。" }
        },
        "required": ["evidenceStatus"]
      },
      "AiInteractionLogRequest": {
        "type": "object",
        "description": "AI 交互日志（补充接口，对接文档未列入前端必接）。",
        "properties": {
          "sessionId": { "type": "string", "nullable": true },
          "pageType": { "type": "string", "nullable": true },
          "policyId": { "type": "integer", "format": "int64", "nullable": true },
          "entUid": { "type": "string", "nullable": true },
          "questionCategory": { "type": "string", "nullable": true },
          "resultStatus": { "type": "string", "nullable": true }
        }
      },
      "BooleanResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/ApiResponseEnvelope" },
          { "type": "object", "properties": { "data": { "type": "boolean", "nullable": true } } }
        ]
      }
    },
    "parameters": {
      "PolicyCopilotServiceTokenHeader": {
        "name": "X-Policy-Copilot-Service-Token",
        "in": "header",
        "required": false,
        "schema": { "type": "string" },
        "description": "MCP server 到 Java 的服务间调用凭证（仅服务间使用，浏览器/前端不携带）。本期前端联调阶段免鉴权，前端调用无需此头。"
      }
    }
  }
}
